# Required - app will not start without this
# Local Postgres (Docker): postgresql://postgres:postgres@localhost:5432/voice_agent_studio
# Neon (serverless):       postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_agent_studio

# --- Provider selection ---

# Chat provider: openai | groq
CHAT_PROVIDER=openai
# Chat model (leave blank for auto-select):
#   openai: gpt-4o, gpt-4o-mini, gpt-4-turbo
#   groq:   llama-3.1-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
CHAT_MODEL=
# TTS provider: openai | deepgram
TTS_PROVIDER=openai

# --- API keys (provide keys for your selected providers) ---

# OpenAI - used for chat (default), TTS (default), OCR, transcription,
#          and real-time voice agent (OpenAI Realtime API)
OPENAI_API_KEY=

# Groq - only needed if CHAT_PROVIDER=groq (free tier: 30 RPM, 6K TPM)
GROQ_API_KEY=

# Deepgram - used for STT (voice input), and TTS if TTS_PROVIDER=deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

# --- Optional integrations ---

# Webex room/message sync (bot token recommended, never expires)
WEBEX_ACCESS_TOKEN=
# Optional fallback. The /demo-setup page can set the active room from a tester's Webex email.
WEBEX_SPACE_ID=

# Twilio - Voice. SMS is disabled by default for Cisco Live demo compliance.
# Get credentials from https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional: only enable if the environment is approved for SMS compliance.
DEMO_ENABLE_SMS=false
DEMO_CONFIRMATION_CHANNEL=webex
# Public URL of this app (used to construct Twilio webhook URLs)
# Replit: https://your-app.replit.app or your custom domain
# Local+ngrok: https://your-id.ngrok-free.app
# Production: https://webex-voice-agent-studio.org
APP_BASE_URL=

# Voice call messages (customize per agent/brand)
TWILIO_VOICE_GREETING=Welcome to Webex Voice Agent Studio. Please leave your message after the tone.
TWILIO_VOICE_NO_RECORDING=We did not receive a recording. Goodbye.
TWILIO_VOICE_FAREWELL=Thank you. Your message has been received. Goodbye.

# Avatar rendering (Anam.ai)
ANAM_API_KEY=

# Docker Compose host port (default: 3000)
APP_PORT=3000

# SSL workaround for local development (disables TLS cert verification)
# Required if you see "unable to get local issuer certificate" errors
# Do NOT use in production — set NODE_EXTRA_CA_CERTS=/path/to/certs.pem instead
NODE_TLS_REJECT_UNAUTHORIZED=0
